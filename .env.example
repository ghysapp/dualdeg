# Copy this file to `.env` and fill in your real key.
#
# Get a free API key at https://www.weatherapi.com/signup.aspx
# The free plan includes current conditions, 3-day forecast, astronomy and
# city search — everything this app needs.
#
# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to the JS bundle.
EXPO_PUBLIC_WEATHERAPI_KEY=your_weatherapi_key_here

# --- AdMob (optional) -------------------------------------------------------
# Leave these unset to use Google's test banner ads. Set them to your real
# AdMob banner ad-unit IDs for production builds. The AdMob *App* IDs live in
# app.json under the react-native-google-mobile-ads plugin (currently Google's
# sample/test app IDs — replace before shipping).
# EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
# EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
# Comma-separated AdMob test device IDs (from the device log on first ad load).
# Devices listed here get test ads even from real units — safe verification.
# EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=33BE2250B43518CCDA7DE426D04EE231

# --- GeoIP (optional) -------------------------------------------------------
# Approximate location from IP, used when GPS permission isn't granted.
# The endpoint should return { success, data: { postalCode } }. Without it,
# the app simply has no approximate-location fallback.
# EXPO_PUBLIC_GEOIP_API_URL=https://your-geoip-endpoint.example.com/lookup
# EXPO_PUBLIC_GEOIP_API_KEY=your_geoip_key   # sent as the X-API-Key header

# --- Météo-France (optional) ------------------------------------------------
# France uses Météo-France's free mobile-app forecast API. A shared app token
# is built in; override only if you have your own.
# EXPO_PUBLIC_METEOFRANCE_TOKEN=__your_token__
