{
  "expo": {
    "name": "Weather DualDeg",
    "slug": "dualdeg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dualdeg",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ghysapp.dualdeg",
      "supportsTablet": true,
      "appleTeamId": "YJ3Y64M7F4"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/adaptative-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "allowBackup": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "com.google.android.gms.permission.AD_ID"
      ],
      "package": "com.ghysapp.dualdeg"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidSigning",
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to show the weather where you are."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3427622263556790~7530271119",
          "iosAppId": "ca-app-pub-3427622263556790~7077442603"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This lets us show you more relevant ads. Your choice is respected either way."
        }
      ],
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
